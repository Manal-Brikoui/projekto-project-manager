                container.innerHTML = `
                    <div class="text-center py-8">
                        <svg class="w-12 h-12 mx-auto text-red-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <p class="text-sm text-red-600 font-medium">Loading error</p>
                        <p class="text-xs text-primary-500 mt-1">${error.message}</p>
                    </div>
                `;
            }
        }

        function searchUsers() {
            const searchTerm = document.getElementById('searchUser')?.value?.toLowerCase().trim() || '';

            if (!currentProject || !currentProject.creator_ids) {
                return;
            }

            const currentMemberIds = currentProject.creator_ids.map(id => Number(id));

            const filteredUsers = allUsers.filter(user =>
                !currentMemberIds.includes(Number(user.id)) &&
                (user.name.toLowerCase().includes(searchTerm) || user.email.toLowerCase().includes(searchTerm))
            );

            const container = document.getElementById('userSearchResults');

            if (!filteredUsers.length) {
                container.innerHTML = `
                    <div class="text-center py-8">
                        <svg class="w-12 h-12 mx-auto text-primary-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                        <p class="text-sm text-primary-500 font-medium">No users available</p>
                        <p class="text-xs text-primary-400 mt-1">
                            ${searchTerm ? 'Try another search term' : 'All users are already members'}
                        </p>
                    </div>
                `;
                return;
            }

            container.innerHTML = filteredUsers.map(user => `
                <div class="flex items-center gap-3 p-3 bg-primary-50/30 border border-neutral-light/30 rounded-lg hover:bg-primary-50/50 transition-all">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-green-400 to-accent flex items-center justify-center text-white font-bold shrink-0">
                        ${user.name.charAt(0).toUpperCase()}
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-semibold text-primary-600 truncate">${user.name}</p>
                        <p class="text-xs text-primary-500/70 truncate">${user.email}</p>
                    </div>
                    <button
                        class="px-3 py-1.5 text-sm text-white bg-gradient-to-r from-green-500 to-green-600 rounded-lg hover:from-green-600 hover:to-green-700 transition-all font-medium shrink-0 flex items-center gap-1 shadow-sm"
                        onclick="addMember(${user.id})"
                    >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        Add
                    </button>
                </div>
            `).join('');
        }

        async function addMember(userId) {
            if (!currentProject || !currentProject.id) {
                showMessage('Project not loaded', 'error');
                return;
            }

            try {
                const response = await fetch(`/projects/${currentProject.id}/add-member`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${userToken}`
                    },
                    body: JSON.stringify({ user_id: userId })
                });

                const result = await response.json();
                
                if (!response.ok) throw new Error(result.message || 'Unknown error');

                showMessage(result.message, 'success');
                await loadProject();
                closeAddMemberModal();

            } catch (error) {
                console.error('Error adding member:', error);
                showMessage(error.message, 'error');
            }
        }

        async function removeMember(userId) {
            if (!currentProject || !currentProject.id) {
                showMessage('Project not loaded', 'error');
                return;
            }

            const user = projectMembers.find(u => Number(u.id) === Number(userId));
            if (!confirm(`Are you sure you want to remove ${user?.name || 'this user'} from the project?`)) {
                return;
            }

            try {
                const response = await fetch(`/projects/${currentProject.id}/remove-member`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${userToken}`
                    },
                    body: JSON.stringify({ user_id: userId })
                });

                const result = await response.json();
                
                if (!response.ok) throw new Error(result.message || 'Unknown error');

                showMessage(result.message, 'success');
                await loadProject();
                
            } catch (error) {
                console.error('Error removing member:', error);
                showMessage(error.message, 'error');
            }
        }

        function confirmDeleteProject() {
            if (!confirm('Are you sure you want to delete this project?\n\nThis action is irreversible and will delete all associated tasks.')) {
                return;
            }
            deleteProject();
        }

        async function deleteProject() {
            if (!currentProject || !currentProject.id) {
                showMessage('Error: project not loaded', 'error');
                return;
            }

            try {
                const response = await fetch(`/projects/delete/${currentProject.id}`, {
                    method: 'DELETE',
                    headers: {
                        'Authorization': `Bearer ${userToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.message || 'Deletion error');
                }

                showMessage('Project deleted successfully', 'success');
                
                setTimeout(() => {
                    // Set active tab to "My Projects"
                    localStorage.setItem('activeProjectTab', 'owned');
                    
                    // Return to previous page
                    if (window.history.length > 1) {
                        window.history.back();
                    } else {
                        window.location.href = '/projects/index';
                    }
                }, 1000);

            } catch (error) {
                console.error('Deletion error:', error);
                showMessage(error.message, 'error');
            }
        }

        function formatDate(dateString) {
            if (!dateString) return 'Not set';
            
            try {
                const date = new Date(dateString);
                if (isNaN(date.getTime())) return 'Invalid date';
                
                const options = { year: 'numeric', month: 'long', day: 'numeric' };
                return date.toLocaleDateString('en-US', options);
            } catch (e) {
                return 'Invalid date';
            }
        }

        function showMessage(message, type) {
            const container = document.getElementById('messageContainer');
            const bgColor = type === 'success' ? 'bg-green-50 border-green-200 text-green-700' : 'bg-red-50 border-red-200 text-red-700';
            const icon = type === 'success' 
                ? `<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>`
                : `<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>`;
            
            container.innerHTML = `
                <div class="${bgColor} border px-4 py-3 rounded-lg flex items-center gap-2 shadow-sm animate-fade-in">
                    ${icon}
                    <span class="font-medium">${message}</span>
                </div>
            `;
            
            setTimeout(() => {
                container.innerHTML = '';
            }, 4000);
        }

        // Event Listeners
        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
            document.getElementById('sidebar')?.classList.toggle('-translate-x-full');
        });

        document.getElementById('addMemberModal')?.addEventListener('click', (e) => {
            if (e.target.id === 'addMemberModal') {
                closeAddMemberModal();
            }
        });

        document.getElementById('editProjectModal')?.addEventListener('click', (e) => {
            if (e.target.id === 'editProjectModal') {
                closeEditModal();
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const addMemberModal = document.getElementById('addMemberModal');
                const editModal = document.getElementById('editProjectModal');
                
                if (addMemberModal && !addMemberModal.classList.contains('hidden')) {
                    closeAddMemberModal();
                }
                
                if (editModal && !editModal.classList.contains('hidden')) {
                    closeEditModal();
                }
            }
        });

        document.getElementById('editProjectForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = {
                title: document.getElementById('editTitle').value.trim(),
                description: document.getElementById('editDescription').value.trim(),
                startdate: document.getElementById('editStartDate').value,
                enddate: document.getElementById('editEndDate').value,
                status: document.getElementById('editStatus').value,
                evaluation: document.getElementById('editEvaluation').value || null
            };

            if (!formData.title) {
                showMessage('Title is required', 'error');
                return;
            }

            if (!formData.startdate || !formData.enddate) {
                showMessage('Dates are required', 'error');
                return;
            }
            
            if (formData.enddate < formData.startdate) {
                showMessage('The end date must be greater than or equal to the start date', 'error');
                return;
            }
            // Validate rating
if (!validateRating()) {
    showMessage('Rating must be between 0 and 10', 'error');
    return;
}

const evaluationValue = document.getElementById('editEvaluation').value;
if (evaluationValue !== '' && (parseFloat(evaluationValue) < 0 || parseFloat(evaluationValue) > 10)) {
    showMessage('Rating must be between 0 and 10', 'error');
    return;
}

            try {
                const response = await fetch(`/projects/update/${currentProject.id}`, {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${userToken}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.message || 'Edit error');
                }

                showMessage('Project updated successfully', 'success');
                closeEditModal();
                
                await loadProject();

            } catch (error) {
                console.error('Edit error:', error);
                showMessage(error.message, 'error');
            }
        });
    </script>

    <style>
        @keyframes fade-in {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .animate-fade-in {
            animation: fade-in 0.3s ease-out;
        }
    </style>
</body>
</html>