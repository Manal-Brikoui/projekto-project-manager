<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Details</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary': {
                            50: '#E8F4F5',
                            100: '#D1E9EB',
                            200: '#A3D3D7',
                            300: '#48C0C4',
                            400: '#2C8E99',
                            500: '#1A435E',
                            600: '#0B243B',
                            700: '#081B2C',
                            800: '#05121D',
                            900: '#020A0F'
                        },
                        'accent': {
                            light: '#48C0C4',
                            DEFAULT: '#2C8E99',
                            dark: '#1A435E'
                        },
                        'neutral': {
                            light: '#D1D9E0',
                            DEFAULT: '#FFFFFF'
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gradient-to-br from-neutral-light/20 via-white to-primary-50 min-h-screen">
    {% include 'components/sidebar.html.twig' %}
    
    <!-- Toggle Sidebar Button (Mobile) -->
    <button id="sidebarToggle" class="fixed top-4 left-4 z-40 lg:hidden bg-primary-600 text-white p-3 rounded-lg shadow-lg hover:bg-primary-500 transition-all">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
    </button>

    <!-- Main Content -->
    <div class="lg:ml-72 transition-all duration-300">
        <!-- Header with Back Button -->
        <div class="bg-white shadow-sm border-b border-neutral-light/50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                <!-- Back Button -->
                <div class="mb-4">
                    <button onclick="goBackToProjects()" class="flex items-center gap-2 px-4 py-2 bg-primary-50 text-primary-600 rounded-lg hover:bg-primary-100 transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                        Back to Projects
                    </button>
                </div>
                
                <!-- Title and Actions -->
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2 flex-wrap">
                            <h1 id="projectTitle" class="text-3xl font-bold text-primary-600">Loading...</h1>
                            <span id="roleTag" class="hidden px-3 py-1 rounded-full text-sm font-medium"></span>
                        </div>
                        <p id="projectStatus" class="text-primary-500 font-semibold"></p>
                    </div>
                    
                    <!-- Action Buttons -->
                    <div id="actionButtons" class="hidden flex gap-2 flex-shrink-0"></div>
                </div>
            </div>
        </div>

        <!-- Messages -->
        <div id="messageContainer" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4"></div>

        <!-- Loading -->
        <div id="loading" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
            <div class="w-16 h-16 border-4 border-accent-light border-t-transparent rounded-full animate-spin mx-auto"></div>
            <p class="mt-4 text-primary-500">Loading project...</p>
        </div>

        <!-- Project Details -->
        <div id="projectDetails" class="hidden max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Main Information -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- Description -->
                    <div class="bg-white rounded-xl shadow-md p-6 border border-neutral-light/30">
                        <div class="flex items-center gap-2 mb-4">
                            <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                            <h2 class="text-xl font-bold text-primary-600">Description</h2>
                        </div>
                        <p id="projectDescription" class="text-primary-500/80 leading-relaxed whitespace-pre-wrap"></p>
                    </div>

                    <!-- Dates and Information -->
                    <div class="bg-white rounded-xl shadow-md p-6 border border-neutral-light/30">
                        <div class="flex items-center gap-2 mb-4">
                            <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <h2 class="text-xl font-bold text-primary-600">Information</h2>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="flex items-center gap-3 p-4 bg-accent-light/10 border border-accent-light/20 rounded-lg">
                                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                <div>
                                    <p class="text-sm font-medium text-primary-500/70">Start Date</p>
                                    <p id="projectStartDate" class="text-lg font-bold text-primary-600"></p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-lg">
                                <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                <div>
                                    <p class="text-sm font-medium text-red-700/70">End Date</p>
                                    <p id="projectEndDate" class="text-lg font-bold text-red-700"></p>
                                </div>
                            </div>
                            <div id="evaluationBox" class="hidden flex items-center gap-3 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
                                <svg class="w-6 h-6 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                </svg>
                                <div>
                                    <p class="text-sm font-medium text-yellow-700/70">Rating</p>
                                    <p id="projectEvaluation" class="text-lg font-bold text-yellow-600"></p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3 p-4 bg-primary-100 border border-primary-200 rounded-lg">
                                <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                </svg>
                                <div>
                                    <p class="text-sm font-medium text-primary-500/70">Members</p>
                                    <p id="projectMembersCount" class="text-lg font-bold text-primary-600">0</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Sidebar -->
                <div class="space-y-6">
                    <!-- Members -->
                    <div class="bg-white rounded-xl shadow-md p-6 border border-neutral-light/30">
                        <div class="flex items-center justify-between mb-4">
                            <div class="flex items-center gap-2">
                                <svg class="w-5 h-5 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                                </svg>
                                <h2 class="text-xl font-bold text-primary-600">Members</h2>
                            </div>
                            <button id="addMemberBtn" class="hidden flex items-center gap-1 px-3 py-1 bg-accent-light text-white text-sm rounded-lg hover:bg-accent transition-all" onclick="openAddMemberModal()">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                </svg>
                                Add
                            </button>
                        </div>
                        <div id="membersList" class="space-y-3">
                            <div class="flex items-center justify-center py-4">
                                <div class="w-6 h-6 border-2 border-accent-light border-t-transparent rounded-full animate-spin"></div>
                            </div>
                        </div>
                    </div>
                    
                    <div id="quickActions" class="hidden bg-white rounded-xl shadow-md p-6 border border-neutral-light/30">
                        <div class="flex items-center justify-center py-8">
                            <div class="w-8 h-8 border-2 border-accent-light border-t-transparent rounded-full animate-spin"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Project Modal -->
    <div id="editProjectModal" class="hidden fixed inset-0 bg-primary-600/50 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl max-w-2xl w-full shadow-2xl max-h-[90vh] overflow-y-auto border border-neutral-light/30">
            <div class="bg-gradient-to-r from-accent-light to-accent text-white p-6 rounded-t-2xl sticky top-0">
                <div class="flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    <div>
                        <h2 class="text-2xl font-bold">Edit Project</h2>
                        <p class="text-sm text-white/80 mt-1">Edit your project information</p>
                    </div>
                </div>
            </div>
            <form id="editProjectForm" class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-primary-600 mb-2">Project Title</label>
                    <input 
                        type="text" 
                        id="editTitle" 
                        required
                        class="w-full px-4 py-3 border border-neutral-light rounded-lg focus:ring-2 focus:ring-accent-light focus:border-transparent"
                        placeholder="Ex: Website Redesign"
                    >
                </div>
                <div>
                    <label class="block text-sm font-semibold text-primary-600 mb-2">Description</label>
                    <textarea 
                        id="editDescription" 
                        rows="4"
                        class="w-full px-4 py-3 border border-neutral-light rounded-lg focus:ring-2 focus:ring-accent-light focus:border-transparent resize-none"
                        placeholder="Describe your project..."
                    ></textarea>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-primary-600 mb-2">Start Date</label>
                        <input 
                            type="date" 
                            id="editStartDate"
                            required
                            class="w-full px-4 py-3 border border-neutral-light rounded-lg focus:ring-2 focus:ring-accent-light focus:border-transparent"
                        >
                        <p id="editStartDateError" class="hidden text-xs text-red-600 mt-1 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                            </svg>
                            The start date cannot be in the past
                        </p>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-primary-600 mb-2">End Date</label>
                        <input 
                            type="date" 
                            id="editEndDate"
                            required
                            class="w-full px-4 py-3 border border-neutral-light rounded-lg focus:ring-2 focus:ring-accent-light focus:border-transparent"
                        >
                        <p id="editEndDateError" class="hidden text-xs text-red-600 mt-1 flex items-center gap-1">
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                            </svg>
                            The end date must be greater than or equal to the start date
                        </p>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-primary-600 mb-2">Status</label>
                    <select 
                        id="editStatus"
                        class="w-full px-4 py-3 border border-neutral-light rounded-lg focus:ring-2 focus:ring-accent-light focus:border-transparent"
                    >
                        <option value="en_attente">Pending</option>
                        <option value="en_cours">In Progress</option>
                        <option value="termine">Completed</option>
                    </select>
                </div>
                <div>
    <label class="block text-sm font-semibold text-primary-600 mb-2">Rating (optional)</label>
    <input 
        type="number" 
        id="editEvaluation"
        min="0"
        max="10"
        step="1"
        class="w-full px-4 py-3 border border-neutral-light rounded-lg focus:ring-2 focus:ring-accent-light focus:border-transparent"
        placeholder="Score out of 10"
    >
    <p id="editEvaluationError" class="hidden text-xs text-red-600 mt-1 flex items-center gap-1">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        Rating must be between 0 and 10
    </p>
</div>
                <div class="flex gap-3 pt-4 border-t border-neutral-light/50">
                    <button type="button" onclick="closeEditModal()" class="flex-1 px-6 py-3 border border-neutral-light text-primary-500 rounded-lg hover:bg-primary-50 transition-all font-medium">
                        Cancel
                    </button>
                    <button type="submit" id="editSaveButton" class="flex-1 flex items-center justify-center gap-2 px-6 py-3 bg-gradient-to-r from-accent-light to-accent text-white rounded-lg hover:from-accent hover:to-accent-dark transition-all font-medium shadow-lg">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/>
                        </svg>
                        Save
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add Member Modal -->
    <div id="addMemberModal" class="hidden fixed inset-0 bg-primary-600/50 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl max-w-md w-full shadow-2xl border border-neutral-light/30">
            <div class="bg-gradient-to-r from-accent-light to-accent text-white p-6 rounded-t-2xl">
                <div class="flex items-center gap-3">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                    </svg>
                    <div>
                        <h2 class="text-2xl font-bold">Add Member</h2>
                        <p class="text-sm text-white/80 mt-1">Search and add users to the project</p>
                    </div>
                </div>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-primary-600 mb-2">Search for a User</label>
                    <div class="relative">
                        <input 
                            type="text" 
                            id="searchUser" 
                            placeholder="Search by name or email..."
                            class="w-full px-4 py-3 pl-10 border border-neutral-light rounded-lg focus:ring-2 focus:ring-accent-light focus:border-transparent" 
                            oninput="searchUsers()"
                        >
                        <svg class="w-5 h-5 text-primary-400 absolute left-3 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </div>
                </div>
                <div id="userSearchResults" class="max-h-64 overflow-y-auto space-y-2">
                    <div class="flex items-center justify-center py-8">
                        <div class="text-center">
                            <div class="w-8 h-8 border-2 border-accent-light border-t-transparent rounded-full animate-spin mx-auto mb-2"></div>
                            <p class="text-sm text-primary-500">Loading users...</p>
                        </div>
                    </div>
                </div>
                <div class="flex gap-3 pt-4 border-t border-neutral-light/50">
                    <button onclick="closeAddMemberModal()" class="flex-1 px-6 py-3 border border-neutral-light text-primary-500 rounded-lg hover:bg-primary-50 transition-all font-medium">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let currentUserId = null;
        let userToken = null;
        let currentProject = null;
        let projectMembers = [];
        let projectTasks = [];
        let isOwner = false;
        let allUsers = [];
        const projectId = window.location.pathname.split('/').pop();

        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('token') || localStorage.getItem('jwt_token');
            const user = JSON.parse(localStorage.getItem('user') || '{}');
            
            if (!token || !user.id) {
                console.error('Token or user missing - Redirecting to login');
                window.location.href = '/users/login-form';
                return;
            }

            currentUserId = user.id;
            userToken = token;
           
            await loadProject();
        });

        function goBackToProjects() {
            const tabToShow = isOwner ? 'owned' : 'shared';
            localStorage.setItem('activeProjectTab', tabToShow);
            
            if (window.history.length > 1) {
                window.history.back();
            } else {
                window.location.href = '/projects/index';
            }
        }

        async function loadProject() {
            try {
                const response = await fetch(`/projects/${projectId}`, {
                    headers: {
                        'Authorization': `Bearer ${userToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                if (response.status === 401 || response.status === 403) {
                    localStorage.removeItem('token');
                    localStorage.removeItem('jwt_token');
                    localStorage.removeItem('user');
                    window.location.href = '/users/login-form';
                    return;
                }

                if (!response.ok) {
                    throw new Error('Project not found');
                }

                currentProject = await response.json();
                const currentUserIdNum = Number(currentUserId);
                const creatorIdNum = Number(currentProject.creator_id);
                
                // I am the owner IF AND ONLY IF I am the original creator_id
                isOwner = creatorIdNum === currentUserIdNum;

                // Check if I am a member (in members OR creator_ids)
                let isMember = false;
                
                // Check in members array
                if (Array.isArray(currentProject.members)) {
                    isMember = currentProject.members.some(member => 
                        Number(member.id) === currentUserIdNum
                    );
                }
                
                // Also check in creator_ids (users added to project)
                if (!isMember && Array.isArray(currentProject.creator_ids)) {
                    isMember = currentProject.creator_ids.some(id => 
                        Number(id) === currentUserIdNum
                    );
                }

                // I must be either owner or member
                if (!isMember && !isOwner) {
                    showMessage('You do not have access to this project', 'error');
                    setTimeout(() => window.location.href = '/projects/index', 2000);
                    return;
                }

                console.log(' Project access:', {
                    projectId: currentProject.id,
                    title: currentProject.title,
                    currentUserId: currentUserIdNum,
                    creatorId: creatorIdNum,
                    isOwner: isOwner,
                    isMember: isMember
                });

                displayProject();
                await loadMembers();
                await loadProjectTasks();

            } catch (error) {
                console.error('Error:', error);
                showMessage('Unable to load project', 'error');
                setTimeout(() => window.location.href = '/projects/index', 2000);
            } finally {
                document.getElementById('loading').classList.add('hidden');
                document.getElementById('projectDetails').classList.remove('hidden');
            }
        }

        function displayProject() {
            document.getElementById('projectTitle').textContent = currentProject.title;
            
            const roleTag = document.getElementById('roleTag');
            roleTag.classList.remove('hidden');
            if (isOwner) {
                roleTag.innerHTML = `
                    <svg class="w-4 h-4 inline" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.070-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    Owner
                `;
                roleTag.className = 'px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-sm font-medium inline-flex items-center gap-1';
            } else {
                roleTag.innerHTML = `
                    <svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
