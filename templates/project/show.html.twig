        async function loadMembers() {
            try {
                projectMembers = [];
                const creatorIdNum = Number(currentProject.creator_id);
                
                console.log('[MEMBERS] Loading members - Creator ID:', creatorIdNum);
                console.log('[DATA] Received:', {
                    creator_id: currentProject.creator_id,
                    creator_ids: currentProject.creator_ids,
                    members: currentProject.members
                });
                
                // Utiliser creator_ids (contient TOUS les membres du projet)
                if (currentProject.creator_ids && currentProject.creator_ids.length > 0) {
                    for (const userId of currentProject.creator_ids) {
                        const userIdNum = Number(userId);
                        
                        try {
                           const userResponse = await fetch(`/users/view/${userIdNum}`, {
                                headers: {
                                    'Authorization': `Bearer ${userToken}`,
                                    'Content-Type': 'application/json'
                                }
                            });
                            
                            if (userResponse.ok) {
                                const user = await userResponse.json();
                                //  Comparer avec creator_id (pas avec le premier membre!)
                                const isThisUserTheOwner = userIdNum === creatorIdNum;
                                
                                projectMembers.push({
                                    id: user.id,
                                    name: user.name,
                                    email: user.email,
                                    isOwner: isThisUserTheOwner
                                });
                                
                                console.log(`[${isThisUserTheOwner ? 'OWNER' : 'MEMBER'}] ${user.name} (ID: ${userIdNum}) - Owner: ${isThisUserTheOwner}`);
                            }
                        } catch (error) {
                            console.error('[ERROR] Loading user', userIdNum, ':', error);
                        }
                    }
                }
                
                // propriétaire en premier
                projectMembers.sort((a, b) => {
                    if (a.isOwner && !b.isOwner) return -1;
                    if (!a.isOwner && b.isOwner) return 1;
                    return a.name.localeCompare(b.name);
                });
                
                console.log('[FINAL] Members list:', projectMembers.map(m => ({
                    id: m.id,
                    name: m.name,
                    isOwner: m.isOwner
                })));
                
                displayMembers();
            } catch (error) {
                console.error('[ERROR] Loading members:', error);
            }
        }
