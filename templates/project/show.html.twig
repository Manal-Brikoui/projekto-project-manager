        function setMinimumDates() {
            const today = new Date().toISOString().split('T')[0];
            
            const editStartDateInput = document.getElementById('editStartDate');
            const editEndDateInput = document.getElementById('editEndDate');
            
            if (editStartDateInput) {
                const initialStartDate = editStartDateInput.value;
                
                editStartDateInput.setAttribute('min', today);
                
                editStartDateInput.addEventListener('input', function(e) {
                    const newValue = e.target.value;
                    
                    if (newValue && newValue < today && newValue !== initialStartDate) {
                        e.target.value = initialStartDate;
                        showMessage(' You cannot select a past date. Original date restored.', 'error');
                    }
                });
                
                editStartDateInput.addEventListener('change', function(e) {
                    validateEditDates();
                    updateEditEndDateMinimum();
                });
                
                if (initialStartDate && initialStartDate < today) {
                    editStartDateInput.removeAttribute('min');
                    
                    editStartDateInput.addEventListener('focus', function(e) {
                        e.target.setAttribute('min', today);
                    }, { once: true });
                    
                    editStartDateInput.addEventListener('blur', function(e) {
                        if (e.target.value === initialStartDate) {
                            e.target.removeAttribute('min');
                        }
                    });
                }
            }
            
            if (editEndDateInput) {
                const initialEndDate = editEndDateInput.value;
            
                editEndDateInput.setAttribute('min', today);
                
                editEndDateInput.addEventListener('input', function(e) {
                    const newValue = e.target.value;
                    
                    if (newValue && newValue < today && newValue !== initialEndDate) {
                        e.target.value = initialEndDate;
                        showMessage(' You cannot select a past date. Original date restored.', 'error');
                    }
                });
                
                editEndDateInput.addEventListener('change', function(e) {
                    validateEditDates();
                });
                
                if (initialEndDate && initialEndDate < today) {
                    editEndDateInput.removeAttribute('min');
                    
                    editEndDateInput.addEventListener('focus', function(e) {
                        const startDate = document.getElementById('editStartDate')?.value;
                        const minDate = startDate && startDate >= today ? startDate : today;
                        e.target.setAttribute('min', minDate);
                    }, { once: true });
                    
                    editEndDateInput.addEventListener('blur', function(e) {
                        if (e.target.value === initialEndDate) {
                            e.target.removeAttribute('min');
                        }
                    });
                }
            }
        }

        function updateEditEndDateMinimum() {
            const today = new Date().toISOString().split('T')[0];
            const startDate = document.getElementById('editStartDate')?.value;
            const endDateInput = document.getElementById('editEndDate');
            
            if (startDate && endDateInput) {
                const minDate = startDate >= today ? startDate : today;
                endDateInput.setAttribute('min', minDate);
            }
        }
//validation 
        function validateEditDates() {
            const startDate = document.getElementById('editStartDate')?.value;
            const endDate = document.getElementById('editEndDate')?.value;
            const startDateError = document.getElementById('editStartDateError');
            const endDateError = document.getElementById('editEndDateError');
            const saveButton = document.getElementById('editSaveButton');
            const startDateInput = document.getElementById('editStartDate');
            const endDateInput = document.getElementById('editEndDate');
            
            let isValid = true;
            
            if (startDateError) startDateError.classList.add('hidden');
            if (endDateError) endDateError.classList.add('hidden');
            
            if (startDateInput) {
                startDateInput.classList.remove('border-red-500', 'focus:ring-red-500');
                startDateInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
            }
            
            if (endDateInput) {
                endDateInput.classList.remove('border-red-500', 'focus:ring-red-500');
                endDateInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
            }
            
            if (startDate && endDate) {
                const start = new Date(startDate);
                const end = new Date(endDate);
                
                if (end < start) {
                    if (endDateError) {
                        endDateError.innerHTML = `
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                            </svg>
                            The end date must be greater than or equal to the start date
                        `;
                        endDateError.classList.remove('hidden');
                    }
                    if (endDateInput) {
                        endDateInput.classList.add('border-red-500', 'focus:ring-red-500');
                        endDateInput.classList.remove('border-neutral-light', 'focus:ring-accent-light');
                    }
                    isValid = false;
                }
            }
            
            if (saveButton) {
                saveButton.disabled = !isValid;
                if (!isValid) {
                    saveButton.classList.add('opacity-50', 'cursor-not-allowed');
                } else {
                    saveButton.classList.remove('opacity-50', 'cursor-not-allowed');
                }
            }
            
            return isValid;
        }
        function setupRatingValidation() {
    const evaluationInput = document.getElementById('editEvaluation');
    
    if (!evaluationInput) return;
    
    // Real-time validation during input
    evaluationInput.addEventListener('input', validateRating);
    evaluationInput.addEventListener('change', validateRating);
    
    // Block non-numeric characters
    evaluationInput.addEventListener('keydown', function(e) {
        // Allow: backspace, delete, tab, escape, enter
        if ([46, 8, 9, 27, 13].indexOf(e.keyCode) !== -1 ||
            // Allow: Ctrl+A, Ctrl+C, Ctrl+V, Ctrl+X
            (e.keyCode === 65 && e.ctrlKey === true) ||
            (e.keyCode === 67 && e.ctrlKey === true) ||
            (e.keyCode === 86 && e.ctrlKey === true) ||
            (e.keyCode === 88 && e.ctrlKey === true) ||
            // Allow: home, end, left, right
            (e.keyCode >= 35 && e.keyCode <= 39)) {
            return;
        }
        
        // Block if not a number
        if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && 
            (e.keyCode < 96 || e.keyCode > 105)) {
            e.preventDefault();
        }
    });
}

function validateRating() {
    const evaluationInput = document.getElementById('editEvaluation');
    const evaluationError = document.getElementById('editEvaluationError');
    
    if (!evaluationInput) return true;
    
    const value = evaluationInput.value;
    
    // If empty, it's valid (optional field)
    if (value === '') {
        hideError();
        return true;
    }
    
    const numValue = parseFloat(value);
    
    // Check if it's a valid number
    if (isNaN(numValue)) {
        showError();
        evaluationInput.value = '';
        return false;
    }
    
    // Check range 0-10
    if (numValue < 0 || numValue > 10) {
        showError();
        // Auto-correct value
        if (numValue < 0) evaluationInput.value = '0';
        else if (numValue > 10) evaluationInput.value = '10';
        return false;
    }
    
    hideError();
    return true;
    
    function showError() {
        if (evaluationError) evaluationError.classList.remove('hidden');
        evaluationInput.classList.add('border-red-500', 'focus:ring-red-500');
        evaluationInput.classList.remove('border-neutral-light', 'focus:ring-accent-light');
    }
    
    function hideError() {
        if (evaluationError) evaluationError.classList.add('hidden');
        evaluationInput.classList.remove('border-red-500', 'focus:ring-red-500');
        evaluationInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
    }
}

