                switchTab('owned');
            }
        }

        async function loadTasks() {
            try {
                const response = await fetch(`/users/view/${currentUserId}/tasks`, {
                    headers: {
                        'Authorization': `Bearer ${userToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                if (!response.ok) throw new Error('Erreur');
                
                const tasks = await response.json();
                displayTasks(tasks);
            } catch (error) {
                console.error('Error loading tasks:', error);
                const tasksList = document.getElementById('tasksList');
                if (tasksList) {
                    tasksList.innerHTML = '<p class="text-xs text-red-400">Error</p>';
                }
            }
        }

        function displayTasks(tasks) {
            const container = document.getElementById('tasksList');
            const count = document.getElementById('tasksCount');
            
            if (!container || !count) return;
            
            count.textContent = tasks.length;

            if (tasks.length === 0) {
                container.innerHTML = '<p class="text-xs text-neutral-light/70 italic">No tasks</p>';
                return;
            }

            container.innerHTML = tasks.slice(0, 5).map(task => `
                <div class="flex items-center gap-2 px-3 py-2 text-sm text-neutral-light hover:bg-primary-500/30 rounded-lg transition-all">
                    <div class="w-2 h-2 rounded-full ${getTaskStatusColor(task.status)}"></div>
                    <span class="flex-1 truncate">${task.title}</span>
                </div>
            `).join('');

            if (tasks.length > 5) {
                container.innerHTML += `<p class="text-xs text-neutral-light/70 italic px-3 py-2">+${tasks.length - 5} more</p>`;
            }
        }

        function switchTab(tab) {
            currentTab = tab;
            localStorage.setItem('activeProjectTab', tab);
            
            const tabOwned = document.getElementById('tabOwned');
            const tabShared = document.getElementById('tabShared');
            const ownedContainer = document.getElementById('ownedProjectsContainer');
            const sharedContainer = document.getElementById('sharedProjectsContainer');
            
            if (tab === 'owned') {
                tabOwned.className = 'py-4 px-1 border-b-2 border-accent-light font-medium text-sm text-accent-light';
                tabShared.className = 'py-4 px-1 border-b-2 border-transparent font-medium text-sm text-primary-500/70 hover:text-primary-500 hover:border-neutral-light';
                ownedContainer.classList.remove('hidden');
                sharedContainer.classList.add('hidden');
            } else {
                tabOwned.className = 'py-4 px-1 border-b-2 border-transparent font-medium text-sm text-primary-500/70 hover:text-primary-500 hover:border-neutral-light';
                tabShared.className = 'py-4 px-1 border-b-2 border-primary-400 font-medium text-sm text-primary-400';
                ownedContainer.classList.add('hidden');
                sharedContainer.classList.remove('hidden');
            }
        }

        function openModal() {
            const modalIcon = document.getElementById('modalIcon');
            const modalTitle = document.getElementById('modalTitle');
            const submitBtn = document.getElementById('submitBtn');
            const submitIcon = document.getElementById('submitIcon');
            
            modalIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>';
            modalTitle.textContent = 'Create New Project';
            submitBtn.textContent = 'Create Project';
