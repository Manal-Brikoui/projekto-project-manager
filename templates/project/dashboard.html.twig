       function resetForm() {
    document.getElementById('projectId').value = '';
    document.getElementById('title').value = '';
    document.getElementById('description').value = '';
    document.getElementById('startdate').value = '';
    document.getElementById('enddate').value = '';
    document.getElementById('status').value = 'en_cours';
    document.getElementById('evaluation').value = '';
    
    // Réactiver les champs de date
    const startDateInput = document.getElementById('startdate');
    const endDateInput = document.getElementById('enddate');
    if (startDateInput) startDateInput.disabled = false;
    if (endDateInput) endDateInput.disabled = false;
    
    // Supprimer le message d'avertissement
    const warning = document.getElementById('dateWarning');
    if (warning) warning.remove();
    
    const startDateError = document.getElementById('startDateError');
    const endDateError = document.getElementById('endDateError');
    
    if (startDateError) startDateError.classList.add('hidden');
    if (endDateError) endDateError.classList.add('hidden');
    // Validate rating
if (!validateRating()) {
    showMessage('Rating must be between 0 and 10', 'error');
    return;
}

const evaluationValue = document.getElementById('evaluation').value;
if (evaluationValue !== '' && (parseFloat(evaluationValue) < 0 || parseFloat(evaluationValue) > 10)) {
    showMessage('Rating must be between 0 and 10', 'error');
    return;
}
    
    if (startDateInput) {
        startDateInput.classList.remove('border-red-500', 'focus:ring-red-500');
        startDateInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
    }
    
    if (endDateInput) {
        endDateInput.classList.remove('border-red-500', 'focus:ring-red-500');
        endDateInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
    }
    
    const saveButton = document.getElementById('saveButton');
    if (saveButton) {
        saveButton.disabled = false;
        saveButton.classList.remove('opacity-50', 'cursor-not-allowed');
    }
}

        function viewProject(projectId) {
            localStorage.setItem('activeProjectTab', currentTab);
            window.location.href = `/projects/show/${projectId}`;
        }

       async function editProject(projectId) {
    try {
        const response = await fetch(`/projects/${projectId}`, {
            headers: {
                'Authorization': `Bearer ${userToken}`,
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) throw new Error('Loading error');
        
        const project = await response.json();
        
        document.getElementById('projectId').value = project.id;
        document.getElementById('title').value = project.title;
        document.getElementById('description').value = project.description;
        document.getElementById('startdate').value = project.startdate;
        document.getElementById('enddate').value = project.enddate;
        document.getElementById('status').value = project.status;
        document.getElementById('evaluation').value = project.evaluation || '';
        
        const modalIcon = document.getElementById('modalIcon');
        const modalTitle = document.getElementById('modalTitle');
        const submitBtn = document.getElementById('submitBtn');
        const submitIcon = document.getElementById('submitIcon');
        
        modalIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>';
        modalTitle.textContent = 'Edit Project';
        submitBtn.textContent = 'Update';
        submitIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>';
        
        document.getElementById('projectModal').classList.remove('hidden');
        
        // Toujours appliquer le blocage des dates passées
        setTimeout(() => {
            setMinimumDates();
            setupDateValidation();
            // Ne pas valider immédiatement pour permettre l'affichage des dates existantes
        }, 100);
    } catch (error) {
        showMessage('Unable to load project', 'error');
    }
}
async function saveProject() {
    const projectId = document.getElementById('projectId').value;
    const isNewProject = !projectId;
    
    const data = {
        title: document.getElementById('title').value,
        description: document.getElementById('description').value,
        startdate: document.getElementById('startdate').value,
        enddate: document.getElementById('enddate').value,
        status: document.getElementById('status').value,
        evaluation: document.getElementById('evaluation').value
    };

    if (!data.title || !data.description || !data.startdate || !data.enddate) {
        showMessage('All required fields must be filled', 'error');
        return;
    }
    // Validate rating
if (!validateRating()) {
    showMessage('Rating must be between 0 and 10', 'error');
    return;
}

const evaluationValue = document.getElementById('evaluation').value;
if (evaluationValue !== '' && (parseFloat(evaluationValue) < 0 || parseFloat(evaluationValue) > 10)) {
    showMessage('Rating must be between 0 and 10', 'error');
    return;
}

    const today = new Date().toISOString().split('T')[0];
    
    // Validation des dates passées UNIQUEMENT pour les nouveaux projets
    if (isNewProject) {
        if (data.startdate < today) {
            showMessage('The start date cannot be in the past', 'error');
            return;
        }
        
        if (data.enddate < today) {
            showMessage('The end date cannot be in the past', 'error');
            return;
        }
    }
    
    // Validation de cohérence (toujours active)
    if (data.enddate < data.startdate) {
        showMessage('The end date must be greater than or equal to the start date', 'error');
        return;
    }

    const url = projectId ? `/projects/update/${projectId}` : '/projects/add';
    const method = projectId ? 'PUT' : 'POST';

    try {
        const response = await fetch(url, {
            method,
            headers: {
                'Authorization': `Bearer ${userToken}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        });

        const result = await response.json();

        if (!response.ok) {
            throw new Error(result.error || result.message || 'Error');
        }

        showMessage(projectId ? 'Project updated successfully' : 'Project created successfully', 'success');
        closeModal();
        localStorage.setItem('activeProjectTab', 'owned');
        await loadProjects();
        switchTab('owned');
    } catch (error) {
        showMessage(error.message, 'error');
    }
}
        async function deleteProject(projectId) {
            if (!confirm('Are you sure you want to delete this project? This action is irreversible.')) return;

            try {
                const response = await fetch(`/projects/delete/${projectId}`, {
                    method: 'DELETE',
                    headers: {
                        'Authorization': `Bearer ${userToken}`,
                        'Content-Type': 'application/json'
                    }
                });

                const result = await response.json();

                if (!response.ok) {
                    throw new Error(result.message || 'Deletion error');
                }

                showMessage('Project deleted successfully.', 'success');
                await loadProjects();
            } catch (error) {
                showMessage(error.message, 'Error');
            }
        }

        function toggleSection(section) {
            const list = document.getElementById(`${section}List`);
            const icon = document.getElementById(`${section}Icon`);
            
            if (list && icon) {
                list.classList.toggle('hidden');
                icon.classList.toggle('rotate-180');
            }
        }

        function getStatusColor(status) {
            const colors = {
                'en_cours': 'bg-accent-light',
                'termine': 'bg-green-500',
                'en_attente': 'bg-yellow-500'
            };
            return colors[status] || 'bg-neutral-light';
        }

        function getStatusBadge(status) {
    const badges = {
        'en_cours': { color: 'bg-accent-light/20 text-primary-50', label: 'In Progress' },
        'termine': { color: 'bg-green-100 text-green-700', label: 'Completed' },
        'en_attente': { color: 'bg-yellow-100 text-yellow-700', label: 'Pending' }
    };
    
    const badge = badges[status] || badges['en_cours'];
    return `<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium ${badge.color}">${badge.label}</span>`;
}

        function getTaskStatusColor(status) {
            const colors = {
                'todo': 'bg-neutral-light',
                'in_progress': 'bg-accent-light',
                'done': 'bg-green-500'
            };
            return colors[status] || 'bg-neutral-light';
        }

        function showMessage(message, type) {
            const container = document.getElementById('messageContainer');
            if (!container) return;
            
            const bgColor = type === 'success' ? 'bg-green-50 border-green-200 text-green-700' : 'bg-red-50 border-red-200 text-red-700';
            const icon = type === 'success' ? 
                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>' :
                '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>';
            
            container.innerHTML = `
                <div class="${bgColor} border px-4 py-3 rounded-lg flex items-center gap-2 animate-pulse">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        ${icon}
                    </svg>
                    ${message}
                </div>
            `;
            
            setTimeout(() => container.innerHTML = '', 4000);
        }

        function logout() {
            if (confirm('Do you really want to log out?')) {
                localStorage.removeItem('token');
                localStorage.removeItem('user');
                localStorage.removeItem('activeProjectTab');
                window.location.href = '/users/login-form';
            }
        }

        const sidebarToggle = document.getElementById('sidebarToggle');
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                const sidebar = document.getElementById('sidebar');
                if (sidebar) {
                    sidebar.classList.toggle('-translate-x-full');
                }
            });
        }

        document.getElementById('projectModal')?.addEventListener('click', (e) => {
            if (e.target.id === 'projectModal') {
                closeModal();
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const modal = document.getElementById('projectModal');
                if (modal && !modal.classList.contains('hidden')) {
                    closeModal();
                }
            }
        });
    </script>
    <script>

(function() {
    'use strict';
    
    console.log(' [HEADER] Initialisation du badge header');
    
    const BADGE_ID = 'notifBadgeHeader';
    let retryCount = 0;
    const MAX_RETRIES = 15;
    
    function updateHeaderBadge(count) {
        const badge = document.getElementById(BADGE_ID);
        
        if (!badge) {
            console.warn('[HEADER] Badge header non trouvé');
            return;
        }
        
        console.log(' [HEADER] Mise à jour badge header:', count);
        
        if (count > 0) {
            badge.textContent = count > 99 ? '99+' : count;
            badge.classList.remove('hidden');
            badge.style.display = 'flex';
        } else {
            badge.classList.add('hidden');
            badge.style.display = 'none';
        }
    }
    

    window.addEventListener('notificationCountUpdated', (event) => {
        console.log(' [HEADER] Event reçu:', event.detail);
        if (event.detail && typeof event.detail.unreadCount === 'number') {
            updateHeaderBadge(event.detail.unreadCount);
        }
    });
    
    //  Initialisation avec retry
    function init() {
        console.log(` [HEADER] Tentative init ${retryCount + 1}/${MAX_RETRIES}`);
        
        if (window.NotificationSync && window.NotificationSync.isInitialized()) {
            const count = window.NotificationSync.getCount();
            console.log(' [HEADER] NotificationSync prêt, count:', count);
            updateHeaderBadge(count);
        } else if (retryCount < MAX_RETRIES) {
            retryCount++;
            setTimeout(init, 300);
        } else {
            console.error(' [HEADER] Timeout - Tentative fallback');
            fetchCountManually();
        }
    }
    
  
    async function fetchCountManually() {
        try {
            const token = localStorage.getItem('token') || localStorage.getItem('jwt_token');
            if (!token) {
                console.warn(' [HEADER] Pas de token pour fallback');
                return;
            }
            
            const response = await fetch('/notifications/count', {
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                }
            });
            
            if (response.ok) {
                const data = await response.json();
                console.log(' [HEADER] Count récupéré manuellement:', data.count);
                updateHeaderBadge(data.count);
            } else {
                console.error(' [HEADER] Erreur API:', response.status);
            }
        } catch (error) {
            console.error(' [HEADER] Erreur récupération manuelle:', error);
        }
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        setTimeout(init, 100);
    }
    
    console.log(' [HEADER] Script badge header chargé');
})();
</script>
