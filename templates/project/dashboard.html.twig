    <script>
    let currentUserId = null;
    let userToken = null;
    let allProjects = [];
    let currentTab = 'owned';
    document.addEventListener('DOMContentLoaded', async () => {
        const token = localStorage.getItem('token');
        const user = JSON.parse(localStorage.getItem('user') || '{}');
        
        if (!token || !user.id) {
            window.location.href = '/users/login-form';
            return;
        }

        currentUserId = user.id;
        userToken = token;
        
        const userEmailElement = document.getElementById('userEmail');
        if (userEmailElement) {
            userEmailElement.textContent = user.email || 'Utilisateur';
        }
          setMinimumDates();
setupDateValidation();
setupRatingValidation();

        try {
            await Promise.all([
                loadProjects(),
                loadTasks()
            ]);
            
            restoreActiveTab();
            
        } catch (error) {
            console.error('Erreur lors du chargement:', error);
        }
    });

    function setMinimumDates() {
    const today = new Date().toISOString().split('T')[0];
    
    const startDateInput = document.getElementById('startdate');
    const endDateInput = document.getElementById('enddate');
    
    if (startDateInput) {
        // Toujours définir min à aujourd'hui
        startDateInput.setAttribute('min', today);
        startDateInput.style.cursor = 'pointer';
        
        const newStartInput = startDateInput.cloneNode(true);
        startDateInput.parentNode.replaceChild(newStartInput, startDateInput);
        
        // Bloquer uniquement lors du changement
        newStartInput.addEventListener('change', function(e) {
            if (e.target.value && e.target.value < today) {
                e.target.value = '';
                showMessage('The start date cannot be in the past. Please choose a date from today onwards.', 'error');
            } else {
                validateDates();
                updateEndDateMinimum();
            }
        });
        
        newStartInput.addEventListener('input', function(e) {
            if (e.target.value && e.target.value < today) {
                const oldValue = e.target.value;
                e.target.value = '';
                showMessage('Cannot enter a past date', 'error');
            }
        });
    }
    
    if (endDateInput) {
        // Toujours définir min à aujourd'hui
        endDateInput.setAttribute('min', today);
        endDateInput.style.cursor = 'pointer';
        
        const newEndInput = endDateInput.cloneNode(true);
        endDateInput.parentNode.replaceChild(newEndInput, endDateInput);
        
        // Bloquer uniquement lors du changement
        newEndInput.addEventListener('change', function(e) {
            if (e.target.value && e.target.value < today) {
                e.target.value = '';
                showMessage('The end date cannot be in the past. Please choose a date from today onwards.', 'error');
            } else {
                validateDates();
            }
        });
        
        newEndInput.addEventListener('input', function(e) {
            if (e.target.value && e.target.value < today) {
                e.target.value = '';
                showMessage('Cannot enter a past date', 'error');
            }
        });
    }
}
    function setupDateValidation() {
        const startDateInput = document.getElementById('startdate');
        const endDateInput = document.getElementById('enddate');
        
        if (startDateInput) {
            // Retirer les anciens événements pour éviter les doublons
            const newStartDateInput = startDateInput.cloneNode(true);
            startDateInput.parentNode.replaceChild(newStartDateInput, startDateInput);
            
            newStartDateInput.addEventListener('change', () => {
                validateDates();
                updateEndDateMinimum();
            });
            newStartDateInput.addEventListener('input', () => {
                validateDates();
                updateEndDateMinimum();
            });
        }
        
        if (endDateInput) {
            // Retirer les anciens événements pour éviter les doublons
            const newEndDateInput = endDateInput.cloneNode(true);
            endDateInput.parentNode.replaceChild(newEndDateInput, endDateInput);
            
            newEndDateInput.addEventListener('change', validateDates);
            newEndDateInput.addEventListener('input', validateDates);
        }
    }

    function updateEndDateMinimum() {
        const startDate = document.getElementById('startdate')?.value;
        const endDateInput = document.getElementById('enddate');
        
        if (startDate && endDateInput) {
            endDateInput.setAttribute('min', startDate);
        }
    }
function validateDates() {
    const startDate = document.getElementById('startdate')?.value;
    const endDate = document.getElementById('enddate')?.value;
    const startDateError = document.getElementById('startDateError');
    const endDateError = document.getElementById('endDateError');
    const saveButton = document.getElementById('saveButton');
    const startDateInput = document.getElementById('startdate');
    const endDateInput = document.getElementById('enddate');
    const projectId = document.getElementById('projectId').value;
    
    const today = new Date().toISOString().split('T')[0];
    const isEditing = !!projectId;
    
    let isValid = true;
    
    if (!isEditing) {
        //  bloquer les dates passées
        if (startDate && startDate < today) {
            if (startDateError) startDateError.classList.remove('hidden');
            if (startDateInput) {
                startDateInput.classList.add('border-red-500', 'focus:ring-red-500');
                startDateInput.classList.remove('border-neutral-light', 'focus:ring-accent-light');
            }
            isValid = false;
        } else {
            if (startDateError) startDateError.classList.add('hidden');
            if (startDateInput) {
                startDateInput.classList.remove('border-red-500', 'focus:ring-red-500');
                startDateInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
            }
        }
        
        if (endDate && endDate < today) {
            if (endDateError) {
                endDateError.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg> The end date cannot be in the past';
                endDateError.classList.remove('hidden');
            }
            if (endDateInput) {
                endDateInput.classList.add('border-red-500', 'focus:ring-red-500');
                endDateInput.classList.remove('border-neutral-light', 'focus:ring-accent-light');
            }
            isValid = false;
        } else {
            if (endDateError) endDateError.classList.add('hidden');
            if (endDateInput) {
                endDateInput.classList.remove('border-red-500', 'focus:ring-red-500');
                endDateInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
            }
        }
    } else {
        //  ne pas afficher d'erreurs pour les dates existantes
        if (startDateError) startDateError.classList.add('hidden');
        if (endDateError) endDateError.classList.add('hidden');
        if (startDateInput) {
            startDateInput.classList.remove('border-red-500', 'focus:ring-red-500');
            startDateInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
        }
        if (endDateInput) {
            endDateInput.classList.remove('border-red-500', 'focus:ring-red-500');
            endDateInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
        }
    }
    
    // Validation de cohérence 
    if (startDate && endDate) {
        const start = new Date(startDate);
        const end = new Date(endDate);
        
        if (end < start) {
            if (endDateError) {
                endDateError.innerHTML = '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg> The end date must be greater than or equal to the start date';
                endDateError.classList.remove('hidden');
            }
            if (endDateInput) {
                endDateInput.classList.add('border-red-500', 'focus:ring-red-500');
                endDateInput.classList.remove('border-neutral-light', 'focus:ring-accent-light');
            }
            isValid = false;
        }
    }
    
    if (saveButton) {
        saveButton.disabled = !isValid;
        if (!isValid) {
            saveButton.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
            saveButton.classList.remove('opacity-50', 'cursor-not-allowed');
        }
    }
    
    return isValid;
}
function setupRatingValidation() {
    const evaluationInput = document.getElementById('evaluation');
    
    if (!evaluationInput) return;
    
    // Real-time validation during input
    evaluationInput.addEventListener('input', validateRating);
    evaluationInput.addEventListener('change', validateRating);
    
    // Block non-numeric characters
    evaluationInput.addEventListener('keydown', function(e) {
        // Allow: backspace, delete, tab, escape, enter
        if ([46, 8, 9, 27, 13].indexOf(e.keyCode) !== -1 ||
            // Allow: Ctrl+A, Ctrl+C, Ctrl+V, Ctrl+X
            (e.keyCode === 65 && e.ctrlKey === true) ||
            (e.keyCode === 67 && e.ctrlKey === true) ||
            (e.keyCode === 86 && e.ctrlKey === true) ||
            (e.keyCode === 88 && e.ctrlKey === true) ||
            // Allow: home, end, left, right
            (e.keyCode >= 35 && e.keyCode <= 39)) {
            return;
        }
        
        // Block if not a number
        if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && 
            (e.keyCode < 96 || e.keyCode > 105)) {
            e.preventDefault();
        }
    });
}

function validateRating() {
    const evaluationInput = document.getElementById('evaluation');
    const evaluationError = document.getElementById('evaluationError');
    
    if (!evaluationInput) return true;
    
    const value = evaluationInput.value;
    
    // If empty, it's valid (optional field)
    if (value === '') {
        hideError();
        return true;
    }
    
    const numValue = parseFloat(value);
    
    // Check if it's a valid number
    if (isNaN(numValue)) {
        showError();
        evaluationInput.value = '';
        return false;
    }
    
    // Check range 0-10
    if (numValue < 0 || numValue > 10) {
        showError();
        // Auto-correct value
        if (numValue < 0) evaluationInput.value = '0';
        else if (numValue > 10) evaluationInput.value = '10';
        return false;
    }
    
    hideError();
    return true;
    
    function showError() {
        if (evaluationError) evaluationError.classList.remove('hidden');
        evaluationInput.classList.add('border-red-500', 'focus:ring-red-500');
        evaluationInput.classList.remove('border-neutral-light', 'focus:ring-accent-light');
    }
    
    function hideError() {
        if (evaluationError) evaluationError.classList.add('hidden');
        evaluationInput.classList.remove('border-red-500', 'focus:ring-red-500');
        evaluationInput.classList.add('border-neutral-light', 'focus:ring-accent-light');
    }
}
    async function loadProjects() {
    try {
        const response = await fetch('/projects/', {
            method: 'GET',
            headers: {
                'Authorization': `Bearer ${userToken}`,
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            }
        });

        if (response.status === 401) {
            throw new Error('Not authenticated - Session expired');
        }

        if (!response.ok) {
            const errorText = await response.text();
            console.error('Erreur response:', errorText);
            throw new Error(`HTTP Error ${response.status}`);
        }
        
        allProjects = await response.json();
        console.log(' Tous les projets reçus:', allProjects);
        
        const currentUserIdNum = Number(currentUserId);
        console.log(' ID utilisateur actuel:', currentUserIdNum);
        
        
        // Un projet m'appartient SI et SEULEMENT SI je suis le creator_id original
        const ownedProjects = allProjects.filter(p => {
            const creatorIdNum = Number(p.creator_id);
            const isOwner = creatorIdNum === currentUserIdNum;
            
            if (isOwner) {
                console.log(` Projet propriétaire: ${p.title} (ID: ${p.id}, creator_id: ${p.creator_id})`);
            }
            
            return isOwner;
        });

        // Un projet est partagé SI je suis membre MAIS PAS le créateur original
        const sharedProjects = allProjects.filter(p => {
            const creatorIdNum = Number(p.creator_id);
            const isOriginalCreator = creatorIdNum === currentUserIdNum;
            
            //  Si je suis le créateur original, ce N'EST PAS un projet partagé
            if (isOriginalCreator) {
                console.log(` Exclu des partagés (je suis le créateur): ${p.title}`);
                return false;
            }
            
            // Vérifier si je suis membre du projet
            let isMember = false;
            
            //  Vérifier dans le tableau members
            if (Array.isArray(p.members)) {
                isMember = p.members.some(member => 
                    Number(member.id) === currentUserIdNum
                );
            }
            
            //  Vérifier dans creator_ids (utilisateurs ajoutés)
            if (!isMember && Array.isArray(p.creator_ids)) {
                isMember = p.creator_ids.some(id => 
                    Number(id) === currentUserIdNum
                );
            }
            
            if (isMember) {
                console.log(` Projet partagé: ${p.title} (ID: ${p.id})`);
                console.log('   Créateur original:', p.creator_name, '(ID:', p.creator_id, ')');
                console.log('   Je suis membre mais pas créateur');
            }
            
            return isMember;
        });

        console.log(' Résultat final:');
        console.log('  - Mes projets:', ownedProjects.length);
        console.log('  - Projets partagés:', sharedProjects.length);

        // Mettre à jour les compteurs
        const ownedTabCountEl = document.getElementById('ownedTabCount');
        const sharedTabCountEl = document.getElementById('sharedTabCount');
        const myProjectsCountEl = document.getElementById('myProjectsCount');
        const sharedProjectsCountEl = document.getElementById('sharedProjectsCount');
        
        if (ownedTabCountEl) ownedTabCountEl.textContent = ownedProjects.length;
        if (sharedTabCountEl) sharedTabCountEl.textContent = sharedProjects.length;
        if (myProjectsCountEl) myProjectsCountEl.textContent = ownedProjects.length;
        if (sharedProjectsCountEl) sharedProjectsCountEl.textContent = sharedProjects.length;

        // Afficher les projets
        displayOwnedProjects(ownedProjects);
        displaySharedProjects(sharedProjects);

        // Afficher dans la sidebar
        displaySidebarProjects('myProjectsList', ownedProjects, true);
        displaySidebarProjects('sharedProjectsList', sharedProjects, false);

    } catch (error) {
        console.error(' Erreur loadProjects:', error);
        
        if (error.message.includes('Non authentifié') || error.message.includes('401')) {
            showMessage('Session expired. Reconnection required.', 'error');
            setTimeout(() => {
                localStorage.clear();
                window.location.href = '/users/login-form';
            }, 2000);
        } else {
            showMessage('Unable to load projects', 'error');
        }
    } finally {
        document.getElementById('loading').classList.add('hidden');
        document.getElementById('ownedProjectsContainer').classList.remove('hidden');
    }
}

