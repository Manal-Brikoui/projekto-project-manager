<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projekto - Project Management Made Simple</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            overflow: hidden;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #0B243B 0%, #1A435E 50%, #2C8E99 100%);
        }

        /* Header */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            padding: 16px 48px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
            background: rgba(11, 36, 59, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(209, 217, 224, 0.1);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 16px;
            color: white;
            font-size: 24px;
            font-weight: 600;
        }

        .logo-icon {
            width: 80px;
            height: 80px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: white;
            padding: 8px;
            box-shadow: 0 4px 12px rgba(72, 192, 196, 0.3);
        }

        .logo-icon img {
            width: 210px;
            height: 210px;
            object-fit: contain;
        }

        .header-buttons {
            display: flex;
            gap: 16px;
            align-items: center;
        }

        .btn-signin-header {
            padding: 8px 20px;
            background: transparent;
            border: 1.5px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            color: white;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-signin-header:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.5);
            transform: translateY(-2px);
        }

        .btn-signup-header {
            padding: 8px 20px;
            background: linear-gradient(135deg, #48C0C4 0%, #2C8E99 100%);
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            box-shadow: 0 4px 12px rgba(72, 192, 196, 0.3);
        }

        .btn-signup-header:hover {
            background: linear-gradient(135deg, #2C8E99 0%, #1A435E 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(72, 192, 196, 0.4);
        }

        /* Main Content */
        .main-container {
            height: 100vh;
            display: flex;
            align-items: center;
            padding: 100px 48px 40px 48px;
        }

        .content-wrapper {
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }

        .hero-content {
            animation: fadeInLeft 0.8s ease-out;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            background: rgba(72, 192, 196, 0.15);
            border: 1px solid rgba(72, 192, 196, 0.3);
            border-radius: 24px;
            color: #48C0C4;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 20px;
            letter-spacing: 0.5px;
        }

        .hero-badge svg {
            width: 14px;
            height: 14px;
        }

        h1 {
            color: white;
            font-size: 44px;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 18px;
            letter-spacing: -1px;
        }

        h1 .highlight {
            background: linear-gradient(135deg, #48C0C4 0%, #2C8E99 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-description {
            color: rgba(255, 255, 255, 0.75);
            font-size: 17px;
            line-height: 1.6;
            margin-bottom: 30px;
            max-width: 540px;
        }

        .cta-buttons {
            display: flex;
            gap: 16px;
            margin-bottom: 35px;
        }

        .btn-primary {
            padding: 13px 32px;
            background: linear-gradient(135deg, #48C0C4 0%, #2C8E99 100%);
            border: none;
            border-radius: 10px;
            color: white;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 8px 24px rgba(72, 192, 196, 0.4);
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #2C8E99 0%, #1A435E 100%);
            transform: translateY(-3px);
            box-shadow: 0 12px 32px rgba(72, 192, 196, 0.5);
        }

        .btn-primary svg {
            width: 18px;
            height: 18px;
        }

        .btn-secondary {
            padding: 13px 32px;
            background: transparent;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 10px;
            color: white;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.5);
            transform: translateY(-3px);
        }

        .btn-secondary svg {
            width: 18px;
            height: 18px;
        }

        /* Features */
        .features {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            max-width: 600px;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 14px;
        }

        .feature-item svg {
            width: 22px;
            height: 22px;
            color: #48C0C4;
            flex-shrink: 0;
        }

        /* Hero Image */
        .hero-image {
            position: relative;
            animation: fadeInRight 0.8s ease-out;
            max-height: calc(100vh - 180px);
        }

        .image-container {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 30px 80px rgba(11, 36, 59, 0.6);
            border: 1px solid rgba(209, 217, 224, 0.1);
            max-height: 100%;
        }

        .image-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(72, 192, 196, 0.1) 0%, rgba(44, 142, 153, 0.1) 100%);
            z-index: 1;
        }

        .image-container img {
            width: 100%;
            height: 100%;
            display: block;
            transform: scale(1.05);
            transition: transform 0.6s ease;
        }

        .image-container:hover img {
            transform: scale(1.08);
        }

        /* Floating Elements */
        .floating-card {
            position: absolute;
            background: rgba(26, 67, 94, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 10px;
            padding: 12px 16px;
            box-shadow: 0 8px 32px rgba(11, 36, 59, 0.5);
            border: 1px solid rgba(209, 217, 224, 0.1);
            animation: float 3s ease-in-out infinite;
        }

        .floating-card-1 {
            top: -15px;
            right: -15px;
            animation-delay: 0s;
        }

        .floating-card-2 {
            bottom: 20px;
            left: -20px;
            animation-delay: 1s;
        }

        .card-content {
            display: flex;
            align-items: center;
            gap: 10px;
            color: white;
            font-size: 13px;
            font-weight: 500;
        }

        .card-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: linear-gradient(135deg, #48C0C4 0%, #2C8E99 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card-icon svg {
            width: 18px;
            height: 18px;
        }

        .card-text {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .card-label {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.5);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Animations */
        @keyframes fadeInLeft {
            from {
                opacity: 0;
                transform: translateX(-40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(40px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-12px);
            }
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .content-wrapper {
                gap: 50px;
            }

            h1 {
                font-size: 40px;
            }

            .hero-description {
                font-size: 16px;
            }
        }

        @media (max-width: 968px) {
            .header {
                padding: 14px 32px;
            }

            .main-container {
                padding: 120px 32px 30px 32px;
            }

            .content-wrapper {
                grid-template-columns: 1fr;
                gap: 40px;
                text-align: center;
            }

            .hero-content {
                display: flex;
                flex-direction: column;
                align-items: center;
            }

            h1 {
                font-size: 36px;
            }

            .hero-description {
                max-width: 600px;
                font-size: 15px;
            }

            .cta-buttons {
                justify-content: center;
            }

            .features {
                max-width: 100%;
                justify-content: center;
            }

            .floating-card {
                display: none;
            }

            .hero-image {
                max-height: 300px;
            }
        }

        @media (max-width: 640px) {
            .header {
                padding: 12px 24px;
            }

            .logo {
                font-size: 20px;
            }

            .logo-icon {
                width: 65px;
                height: 65px;
            }

            .header-buttons {
                gap: 10px;
            }

            .btn-signin-header,
            .btn-signup-header {
                padding: 7px 16px;
                font-size: 13px;
            }

            .main-container {
                padding: 100px 20px 25px 20px;
            }

            h1 {
                font-size: 32px;
            }

            .hero-description {
                font-size: 14px;
                margin-bottom: 25px;
            }

            .cta-buttons {
                flex-direction: column;
                width: 100%;
                gap: 12px;
                margin-bottom: 25px;
            }

            .btn-primary,
            .btn-secondary {
                width: 100%;
                justify-content: center;
                padding: 12px 24px;
            }

            .features {
                grid-template-columns: 1fr;
                gap: 14px;
            }

            .hero-image {
                max-height: 250px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="logo">
            <div class="logo-icon">
                <img src="/images/Adobe.png" alt="Projekto Logo">
            </div>
            <span>Projekto</span>
        </div>
        <div class="header-buttons">
            <a href="/users/login-form" class="btn-signin-header">Sign In</a>
            <a href="/users/register-form" class="btn-signup-header">Get Started</a>
        </div>
    </header>

    <!-- Main Content -->
    <main class="main-container">
        <div class="content-wrapper">
            <!-- Hero Content -->
            <div class="hero-content">
                <div class="hero-badge">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    MODERN PROJECT MANAGEMENT
                </div>

                <h1>
                    Manage Projects<br/>
                    with <span class="highlight">Confidence</span>
                </h1>

                <p class="hero-description">
                    Streamline your workflow, collaborate seamlessly with your team, and deliver projects on time with our powerful project management platform.
                </p>

                <div class="cta-buttons">
                    <a href="/users/register-form" class="btn-primary">
                        Start Free Trial
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                        </svg>
                    </a>
                    <a href="/users/login-form" class="btn-secondary">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                        </svg>
                        Sign In
                    </a>
                </div>

                <div class="features">
                    <div class="feature-item">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <span>Easy Setup</span>
                    </div>
                    <div class="feature-item">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                        <span>Team Collaboration</span>
                    </div>
                    <div class="feature-item">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                        </svg>
                        <span>Secure & Safe</span>
                    </div>
                </div>
            </div>

            <!-- Hero Image -->
            <div class="hero-image">
                <div class="image-container">
                    <img src="/images/background.png" alt="Project Management Dashboard">
                </div>

                <!-- Floating Cards -->
                <div class="floating-card floating-card-1">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                            </svg>
                        </div>
                        <div class="card-text">
                            <span class="card-label">Performance</span>
                            <span>95% Success Rate</span>
                        </div>
                    </div>
                </div>

                <div class="floating-card floating-card-2">
                    <div class="card-content">
                        <div class="card-icon">
                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div class="card-text">
                            <span class="card-label">Time Saved</span>
                            <span>40% Faster</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>