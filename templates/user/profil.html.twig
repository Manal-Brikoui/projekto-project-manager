<script>
// Global variables
let currentUser = null;
let token = null;

// Initialization
document.addEventListener('DOMContentLoaded', async () => {
    token = localStorage.getItem('token');
    const user = JSON.parse(localStorage.getItem('user') || '{}');

    if (!token || !user.id) {
        window.location.href = '/users/login-form';
        return;
    }

    await loadUserData();
});

// Load user data
async function loadUserData() {
    try {
        const response = await fetch('/users/me', {
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) throw new Error('Not authenticated');

        currentUser = await response.json();
        displayUserData();
    } catch (error) {
        console.error('Error:', error);
        showError('Error loading data');
        setTimeout(() => window.location.href = '/users/login-form', 2000);
    }
}

// Display data
function displayUserData() {
    // Avatar
    const initials = currentUser.name.split(' ').map(n => n[0]).join('').toUpperCase();
    document.getElementById('avatarDisplay').textContent = initials;

    // Header
    document.getElementById('displayName').textContent = currentUser.name;
    document.getElementById('displayEmail').textContent = currentUser.email;
    document.getElementById('displayRole').textContent = currentUser.role === 'ROLE_CHEF_PROJET' ? 'Project Manager' : 'Engineer';

    // Form
    document.getElementById('userName').value = currentUser.name;
    document.getElementById('userEmail').value = currentUser.email;
    document.getElementById('userRole').value = currentUser.role === 'ROLE_CHEF_PROJET' ? 'Project Manager' : 'Engineer';
}

// Switch tabs
function switchTab(tabName, event) {
    document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
    event.target.classList.add('active');
    document.getElementById(tabName + 'Tab').classList.add('active');
    
    if (tabName === 'danger') {
        loadProjectCount();
    }
    
    if (tabName === 'notifications') {
        loadNotifications();
    }
}

// Update profile
document.getElementById('profileForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = document.getElementById('userName').value;
    const email = document.getElementById('userEmail').value;

    try {
        const response = await fetch(`/users/edit/${currentUser.id}`, {
            method: 'PUT',
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ name, email })
        });

        if (!response.ok) throw new Error('Update error');

        currentUser.name = name;
        currentUser.email = email;
        localStorage.setItem('user', JSON.stringify(currentUser));

        displayUserData();
        showSuccess('Profile updated successfully');
    } catch (error) {
        showError('Error updating profile');
    }
});

// Change password
document.getElementById('passwordForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const currentPassword = document.getElementById('currentPassword').value;
    const newPassword = document.getElementById('newPassword').value;
    const confirmPassword = document.getElementById('confirmPassword').value;

    if (newPassword !== confirmPassword) {
        showError('Passwords do not match');
        return;
    }

    if (!isStrongPassword(newPassword)) {
        showError('Password does not meet security requirements');
        return;
    }

    try {
        const response = await fetch('/users/change-password', {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ currentPassword, newPassword })
        });

        const data = await response.json();

        if (!response.ok) {
            showError(data.message || 'Error changing password');
            return;
        }

        showSuccess('Password changed successfully');
        document.getElementById('passwordForm').reset();
        document.getElementById('strengthFill').className = 'strength-fill';
        document.getElementById('strengthText').textContent = 'Enter a password to see its strength';
    } catch (error) {
        showError('Error changing password');
    }
});

// Check password strength
// NOUVELLE fonction qui combine barre de force + indicateurs visuels
function checkPasswordStrengthWithRequirements() {
    const password = document.getElementById('newPassword').value;
    const fill = document.getElementById('strengthFill');
    const text = document.getElementById('strengthText');

    // Si vide, reset tout
    if (!password) {
        fill.className = 'strength-fill';
        text.textContent = 'Enter a password to see its strength';
        text.style.color = '#64748b';
        
        // Reset les indicateurs visuels
        ['req-length', 'req-uppercase', 'req-lowercase', 'req-number', 'req-special'].forEach(id => {
            const element = document.getElementById(id);
            if (element) {
                element.classList.remove('valid', 'invalid');
            }
        });
        return;
    }

    // Vérifier chaque exigence et mettre à jour les indicateurs
    const requirements = {
        length: password.length >= 8,
        uppercase: /[A-Z]/.test(password),
        lowercase: /[a-z]/.test(password),
        number: /[0-9]/.test(password),
        special: /[!@#$%^&*()\-_=+{};:,<.>?\/\[\]\\|`~]/.test(password)
    };

    // Mettre à jour les indicateurs visuels
    document.getElementById('req-length').classList.toggle('valid', requirements.length);
    document.getElementById('req-length').classList.toggle('invalid', !requirements.length);
    
    document.getElementById('req-uppercase').classList.toggle('valid', requirements.uppercase);
    document.getElementById('req-uppercase').classList.toggle('invalid', !requirements.uppercase);
    
    document.getElementById('req-lowercase').classList.toggle('valid', requirements.lowercase);
    document.getElementById('req-lowercase').classList.toggle('invalid', !requirements.lowercase);
    
    document.getElementById('req-number').classList.toggle('valid', requirements.number);
    document.getElementById('req-number').classList.toggle('invalid', !requirements.number);
    
    document.getElementById('req-special').classList.toggle('valid', requirements.special);
    document.getElementById('req-special').classList.toggle('invalid', !requirements.special);

    // Calculer la force globale (barre existante)
    let strength = 0;
    if (password.length >= 8) strength++;
    if (password.length >= 12) strength++;
    if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
    if (/[0-9]/.test(password)) strength++;
    if (/[!@#$%^&*()\-_=+{};:,<.>?\/\[\]\\|`~]/.test(password)) strength++;

    fill.className = 'strength-fill';
    if (strength < 3) {
        fill.classList.add('strength-weak');
        text.textContent = 'Weak password';
        text.style.color = '#ef4444';
    } else if (strength < 5) {
        fill.classList.add('strength-medium');
        text.textContent = 'Medium password';
        text.style.color = '#f59e0b';
    } else {
        fill.classList.add('strength-strong');
        text.textContent = 'Strong password';
        text.style.color = '#22c55e';
    }
}
// Toggle password visibility 
function togglePasswordVisibility(fieldId, button) {
    const input = document.getElementById(fieldId);
    const eyeIcon = button.querySelector('.eye-icon');
    const eyeOffIcon = button.querySelector('.eye-off-icon');
    
    if (input.type === 'password') {
        input.type = 'text';
        eyeIcon.style.display = 'none';
        eyeOffIcon.style.display = 'block';
    } else {
        input.type = 'password';
        eyeIcon.style.display = 'block';
        eyeOffIcon.style.display = 'none';
    }
}

// Validate strong password
function isStrongPassword(password) {
    if (password.length < 8) return false;
    if (!/[A-Z]/.test(password)) return false;
    if (!/[a-z]/.test(password)) return false;
    if (!/[0-9]/.test(password)) return false;
    if (!/[!@#$%^&*()\-_=+{};:,<.>?\/\[\]\\|`~]/.test(password)) return false;
    return true;
}

function goBack(event) {
    event.preventDefault();
    window.history.back();
}


let notifications = [];

async function loadNotifications() {
    const loader = document.getElementById('notificationsLoader');
    const container = document.getElementById('notificationsContainer');
    const noNotif = document.getElementById('noNotifications');
    const badge = document.getElementById('notifCountBadge');

    loader.style.display = 'block';
    container.innerHTML = '';
    noNotif.style.display = 'none';

    try {
        const response = await fetch('/notifications/me', {
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) throw new Error('Loading error');

        notifications = await response.json();
        loader.style.display = 'none';

        if (notifications.length === 0) {
            noNotif.style.display = 'block';
            badge.style.display = 'none';
            return;
        }

        const unreadCount = notifications.filter(n => !n.is_read).length;
        if (unreadCount > 0) {
            badge.textContent = unreadCount;
            badge.style.display = 'inline-block';
        } else {
            badge.style.display = 'none';
        }

        notifications.forEach(notif => {
            container.appendChild(createNotificationElement(notif));
        });

    } catch (error) {
        console.error('Error:', error);
        loader.style.display = 'none';
        showError('Error loading notifications');
    }
}

function formatExactDate(dateString) {
    const date = new Date(dateString);
    const now = new Date();
    const diffInSeconds = Math.floor((now - date) / 1000);

    const dateOptions = {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    };

    const timeOptions = {
        hour: '2-digit',
        minute: '2-digit'
    };

    if (date.toDateString() === now.toDateString()) {
        if (diffInSeconds < 60) {
            return 'Just now';
        } else if (diffInSeconds < 3600) {
            return `${Math.floor(diffInSeconds / 60)} min ago`;
        } else {
            return `Today at ${date.toLocaleTimeString('en-US', timeOptions)}`;
        }
    }

    const yesterday = new Date(now);
    yesterday.setDate(yesterday.getDate() - 1);
    if (date.toDateString() === yesterday.toDateString()) {
        return `Yesterday at ${date.toLocaleTimeString('en-US', timeOptions)}`;
    }

    if (diffInSeconds < 7 * 24 * 3600) {
        const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
        return `${days[date.getDay()]} at ${date.toLocaleTimeString('en-US', timeOptions)}`;
    }

    if (date.getFullYear() === now.getFullYear()) {
        return `${date.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })} at ${date.toLocaleTimeString('en-US', timeOptions)}`;
    }

    return `${date.toLocaleDateString('en-US', dateOptions)} at ${date.toLocaleTimeString('en-US', timeOptions)}`;
}

function getNotificationIcon(type) {
    const icons = {
        comment: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>',
        assignment: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>',
        mention: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/></svg>',
        update: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>'
    };
    return icons[type] || icons.update;
}

function createNotificationElement(notif) {
    const div = document.createElement('div');
    div.className = `notification-item ${!notif.is_read ? 'unread' : ''}`;
    div.id = `notif-${notif.id}`;

    const iconType = getNotificationIcon(notif.type);
    const exactDate = formatExactDate(notif.created_at);

    div.innerHTML = `
        <div class="notification-header">
            <div class="notification-icon ${notif.type}">
                ${iconType}
            </div>
            <div class="notification-content">
                <p class="notification-message">${notif.message}</p>
                <div class="notification-meta">
                    ${!notif.is_read ? '<span class="notification-unread-dot"></span>' : ''}
                    <span style="display: flex; align-items: center; gap: 0.25rem;">
                        <svg style="width: 0.875rem; height: 0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        ${exactDate}
                    </span>
                    ${notif.sender_name ? `
                        <span style="display: flex; align-items: center; gap: 0.25rem;">
                            <svg style="width: 0.875rem; height: 0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                            <strong>${notif.sender_name}</strong>
                        </span>
                    ` : ''}
                    ${notif.project_title ? `
                        <span style="display: flex; align-items: center; gap: 0.25rem;">
                            <svg style="width: 0.875rem; height: 0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
                            </svg>
                            ${notif.project_title}
                        </span>
                    ` : ''}
                    ${notif.task_title ? `
                        <span style="display: flex; align-items: center; gap: 0.25rem;">
                            <svg style="width: 0.875rem; height: 0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                            </svg>
                            ${notif.task_title}
                        </span>
                    ` : ''}
                </div>
            </div>
            <div class="notification-actions">
                ${!notif.is_read ? `
                    <button class="notification-action-btn" onclick="markNotificationAsRead(${notif.id})" title="Mark as read">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 1.25rem; height: 1.25rem;">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                    </button>
                ` : ''}
                <button class="notification-action-btn" onclick="deleteNotification(${notif.id})" title="Delete">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 1.25rem; height: 1.25rem;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                </button>
            </div>
        </div>
    `;

    return div;
}

async function markNotificationAsRead(id) {
    try {
        const response = await fetch(`/notifications/mark-read/${id}`, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) throw new Error('Error');

        const notifElement = document.getElementById(`notif-${id}`);
        if (notifElement) {
            notifElement.classList.remove('unread');
            notifElement.querySelector('.notification-actions').innerHTML = `
                <button class="notification-action-btn" onclick="deleteNotification(${id})" title="Delete">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 1.25rem; height: 1.25rem;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            `;
        }

        await loadNotifications();

    } catch (error) {
        showError('Error marking notification');
    }
}

async function markAllAsRead() {
    if (!confirm('Mark all notifications as read?')) return;

    try {
        const response = await fetch('/notifications/mark-all-read', {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) throw new Error('Error');

        showSuccess('All notifications marked as read');
        await loadNotifications();

    } catch (error) {
        showError('Error marking notifications');
    }
}

async function deleteNotification(id) {
    if (!confirm('Delete this notification?')) return;

    try {
        const response = await fetch(`/notifications/delete/${id}`, {
            method: 'DELETE',
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) throw new Error('Error');

        const notifElement = document.getElementById(`notif-${id}`);
        if (notifElement) {
            notifElement.style.opacity = '0';
            notifElement.style.transform = 'translateX(-100%)';
            setTimeout(() => notifElement.remove(), 300);
        }

        showSuccess('Notification deleted');
        await loadNotifications();

    } catch (error) {
        showError('Error deleting notification');
    }
}

async function deleteAllNotifications() {
    if (!confirm('Delete ALL notifications? This action is irreversible.')) return;

    try {
        const response = await fetch('/notifications/delete-all', {
            method: 'DELETE',
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) throw new Error('Error');

        showSuccess('All notifications deleted');
        await loadNotifications();

    } catch (error) {
        showError('Error deleting notifications');
    }
}


async function loadProjectCount() {
    try {
        const response = await fetch('/projects/', {
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        });

        if (!response.ok) return;

        const allProjects = await response.json();
        const userProjects = allProjects.filter(
            p => Number(p.creator_id) === Number(currentUser.id)
        );

        const badge = document.getElementById('projectCountBadge');
        const plural = document.getElementById('projectPlural');
        
        if (badge) {
            badge.textContent = `${userProjects.length}`;
            badge.style.color = userProjects.length > 0 ? '#dc2626' : '#22c55e';
        }
        
        if (plural) {
            plural.textContent = userProjects.length > 1 ? 's' : '';
        }
    } catch (error) {
        console.error('Error counting projects:', error);
    }
}

async function confirmDeleteAccountWithProjects() {
    let userProjects = [];
    try {
        const response = await fetch('/projects/', {
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        });

        if (response.ok) {
            const allProjects = await response.json();
            userProjects = allProjects.filter(
                p => Number(p.creator_id) === Number(currentUser.id)
            );
        }
    } catch (error) {
        console.error('Error loading projects:', error);
    }

    const projectCount = userProjects.length;
    const projectList = userProjects.map(p => `  - ${p.title}`).join('\n');

    const confirmed = confirm(
        'CRITICAL WARNING\n\n' +
        'Are you ABSOLUTELY sure you want to delete your account?\n\n' +
        'THIS ACTION IS IRREVERSIBLE\n\n' +
        'This deletion will result in:\n\n' +
        `Deletion of ${projectCount} project${projectCount > 1 ? 's' : ''}:\n${projectList || '  - No projects'}\n\n` +
        'Loss of ALL your data:\n' +
        '  - All your tasks\n' +
        '  - All your comments\n' +
        '  - All your files\n' +
        '  - All your notifications\n\n' +
        'Click OK to continue to final confirmation'
    );

    if (!confirmed) return;

    const finalConfirm = prompt(
        'FINAL CONFIRMATION\n\n' +
        'To confirm the PERMANENT deletion of your account\n' +
        `and your ${projectCount} project${projectCount > 1 ? 's' : ''},\n\n` +
        'Type exactly: DELETE ALL\n\n' +
        '(in uppercase, with the space)'
    );

    if (finalConfirm !== 'DELETE ALL') {
        showError('Deletion cancelled - Incorrect confirmation text');
        return;
    }

    await deleteAccountAndProjects(userProjects);
}

async function deleteAccountAndProjects(userProjects) {
    const totalSteps = userProjects.length + 1;
    let currentStep = 0;

    try {
        showSuccess(`Deletion in progress... (0/${totalSteps})`);

        for (const project of userProjects) {
            try {
                const response = await fetch(`/projects/delete/${project.id}`, {
                    method: 'DELETE',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    }
                });

                if (response.ok) {
                    currentStep++;
                    showSuccess(`Deleting projects... (${currentStep}/${totalSteps})`);
                } else {
                    console.error(`Error deleting project ${project.id}`);
                }
            } catch (error) {
                console.error(`Error project ${project.id}:`, error);
            }
        }

        const accountResponse = await fetch(`/users/delete/${currentUser.id}`, {
            method: 'DELETE',
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            }
        });

        if (!accountResponse.ok) throw new Error('Account deletion error');

        currentStep++;
        showSuccess(`Deletion complete (${currentStep}/${totalSteps})`);

        localStorage.removeItem('token');
        localStorage.removeItem('user');

        showSuccess('Account and projects deleted successfully. Redirecting...');

        setTimeout(() => {
            window.location.href = '/users/register-form';
        }, 3000);

    } catch (error) {
        console.error('Deletion error:', error);
        showError('Error during deletion. Some data may have been deleted.');
    }
}

// Show success message
function showSuccess(message) {
    const alert = document.getElementById('successAlert');
    alert.textContent = message;
    alert.classList.add('show');

    setTimeout(() => {
        alert.classList.remove('show');
    }, 5000);
}

// Show error message
function showError(message) {
    const alert = document.getElementById('errorAlert');
    alert.textContent = message;
    alert.classList.add('show');

    setTimeout(() => {
        alert.classList.remove('show');
    }, 5000);
}
</script>

