
<!-- Modal de notifications -->
<div id="notificationModal" class="hidden fixed inset-0 z-50 overflow-hidden">

    <div class="fixed inset-0 bg-primary-600/50 backdrop-blur-sm transition-opacity" onclick="closeNotificationModal()"></div>
    
    <!-- Panel du modal -->
    <div class="fixed inset-y-0 right-0 max-w-md w-full bg-white shadow-2xl transform transition-transform translate-x-full">
        <!-- Header -->
        <div class="bg-gradient-to-r from-accent-light to-accent text-white p-6">
            <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-3">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
                    </svg>
                    <div>
                        <h2 class="text-2xl font-bold">Notifications</h2>
                        <p class="text-sm text-white/80" id="notifModalCount">0 notification(s)</p>
                    </div>
                </div>
                <button onclick="closeNotificationModal()" class="p-2 hover:bg-white/10 rounded-lg transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            
            <!-- Actions rapides -->
            <div class="flex gap-2 mt-4">
                <button onclick="refreshNotificationsModal()" class="flex-1 px-3 py-2 bg-white/10 hover:bg-white/20 rounded-lg text-sm font-medium transition-colors flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    Refresh
                </button>
                <button onclick="markAllAsReadModal()" class="flex-1 px-3 py-2 bg-green-500/20 hover:bg-green-500/30 rounded-lg text-sm font-medium transition-colors flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Mark all
                </button>
                <button onclick="deleteAllNotificationsModal()" class="px-3 py-2 bg-red-500/20 hover:bg-red-500/30 rounded-lg text-sm font-medium transition-colors flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Liste des notifications -->
        <div id="notificationModalList" class="h-[calc(100vh-220px)] overflow-y-auto p-4">
            <!-- Loading spinner -->
            <div class="flex items-center justify-center py-12">
                <div class="w-12 h-12 border-4 border-accent-light border-t-transparent rounded-full animate-spin"></div>
            </div>
        </div>

        <!-- Footer avec bouton  -->
        <div class="absolute bottom-0 left-0 right-0 bg-white border-t border-neutral-light p-4">
            <button onclick="goToNotificationsPage()" class="w-full px-4 py-3 bg-gradient-to-r from-accent-light to-accent text-white rounded-lg hover:from-accent hover:to-accent-dark transition-all font-medium shadow-lg flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
                View all notifications
            </button>
        </div>
    </div>
</div>

<script>

(function() {
    'use strict';
    
    console.log(' [MODAL] Initialisation du script de notifications modal...');
    
    let modalNotifications = [];
    let modalUserToken = null;
    let modalUpdateInterval = null;

    // FONCTION D'ATTENTE DE NOTIFICATIONSYNC
    function waitForNotificationSync(callback, maxRetries = 20) {
        let retries = 0;
        
        const checkInterval = setInterval(() => {
            if (window.NotificationSync && window.NotificationSync.isInitialized()) {
                clearInterval(checkInterval);
                console.log(' [MODAL] NotificationSync prêt');
                callback();
            } else {
                retries++;
                console.log(` [MODAL] Attente NotificationSync... (${retries}/${maxRetries})`);
                
                if (retries >= maxRetries) {
                    clearInterval(checkInterval);
                    console.error(' [MODAL] Timeout - NotificationSync non disponible');
                    callback(); 
                }
            }
        }, 200);
    }

    //INITIALISATION
    function initNotificationModal() {
        console.log(' [MODAL] Initialisation du modal...');
        
        const token = localStorage.getItem('token') || localStorage.getItem('jwt_token');
        if (!token) {
            console.warn(' [MODAL] Pas de token pour les notifications');
            return;
        }
        modalUserToken = token;
        
        // Attendre que NotificationSync soit prêt
        waitForNotificationSync(() => {
            console.log(' [MODAL] Modal prêt à être utilisé');
            
            // Auto-refresh toutes les 30 secondes (seulement si le modal est ouvert)
            if (modalUpdateInterval) {
                clearInterval(modalUpdateInterval);
            }
            
            modalUpdateInterval = setInterval(() => {
                const modal = document.getElementById('notificationModal');
                if (modal && modal.classList.contains('show')) {
                    console.log(' [MODAL] Rafraîchissement automatique...');
                    loadNotificationsModal();
                }
            }, 30000);
        });
        
        console.log(' [MODAL] Modal notifications initialisé avec succès');
    }

    //  OUVERTURE/FERMETURE 
    window.openNotificationModal = function() {
        console.log(' [MODAL] Ouverture du modal');
        const modal = document.getElementById('notificationModal');
        if (!modal) {
            console.error(' [MODAL] Modal introuvable dans le DOM !');
            return;
        }
        
        modal.classList.remove('hidden');
        
        
        setTimeout(() => {
            modal.classList.add('show');
        }, 10);
        
        // Charger les notifications
        loadNotificationsModal();
    };

    window.closeNotificationModal = function() {
        console.log(' [MODAL] Fermeture du modal');
        const modal = document.getElementById('notificationModal');
        if (!modal) return;
        
        modal.classList.remove('show');
        
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    };

    //NAVIGATION VERS LA PAGE COMPLÈTE 
    window.goToNotificationsPage = function() {
        console.log(' [MODAL] Redirection vers la page complète');
        closeNotificationModal();
        window.location.href = '/notifications/page';
    };

    //  CHARGEMENT DES NOTIFICATIONS 
    window.loadNotificationsModal = async function() {
        if (!modalUserToken) {
            console.warn(' [MODAL] Pas de token disponible');
            return;
        }

        try {
            console.log(' [MODAL] Chargement des notifications...');
            
            const response = await fetch('/notifications/me', {
                headers: {
                    'Authorization': `Bearer ${modalUserToken}`,
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) {
                if (response.status === 401) {
                    console.error(' [MODAL] Session expirée');
                    return;
                }
                throw new Error(`Erreur ${response.status}`);
            }

            modalNotifications = await response.json();
            console.log(' [MODAL] Notifications chargées:', modalNotifications.length);
            
            displayModalNotifications();
            updateModalBadges();

        } catch (error) {
            console.error(' [MODAL] Erreur chargement:', error);
            const container = document.getElementById('notificationModalList');
            if (container) {
                container.innerHTML = `
                    <div class="text-center py-12">
                        <svg class="w-16 h-16 mx-auto text-red-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <p class="text-red-600 font-medium mb-2">Erreur de chargement</p>
                        <button onclick="loadNotificationsModal()" class="px-4 py-2 bg-accent text-white rounded-lg hover:bg-accent-dark text-sm">
                            Réessayer
                        </button>
                    </div>
                `;
            }
        }
    };

    // AFFICHAGE
    function displayModalNotifications() {
        const container = document.getElementById('notificationModalList');
        const countLabel = document.getElementById('notifModalCount');
        
        if (!container || !countLabel) {
            console.warn(' [MODAL] Conteneur ou label manquant');
            return;
        }
        
        const unreadCount = modalNotifications.filter(n => !n.is_read).length;
        countLabel.textContent = unreadCount > 0 
            ? `${unreadCount} unread` 
            : `${modalNotifications.length} notification(s)`;
        
        console.log(' [MODAL] Affichage de', modalNotifications.length, 'notifications (',unreadCount, 'non lues)');
        
        if (modalNotifications.length === 0) {
            container.innerHTML = `
                <div class="text-center py-16">
                    <svg class="w-20 h-20 mx-auto text-primary-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                    </svg>
                    <p class="text-lg text-primary-600 font-medium mb-2">No notifications</p>
                    <p class="text-sm text-primary-500/70">You're all caught up!</p>
                </div>
            `;
            return;
        }

        // Limiter à 10 notifications les plus récentes
        const recentNotifications = modalNotifications.slice(0, 10);

        container.innerHTML = `
            <div class="space-y-3">
                ${recentNotifications.map(notif => createModalNotificationCard(notif)).join('')}
            </div>
            ${modalNotifications.length > 10 ? `
                <div class="mt-4 text-center">
                    <p class="text-sm text-primary-500/70 mb-2">+${modalNotifications.length - 10} more notifications</p>
                    <button onclick="goToNotificationsPage()" class="text-sm text-accent hover:text-accent-dark font-medium flex items-center gap-1 mx-auto">
                        View all
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </button>
                </div>
            ` : ''}
        `;
    }

    function createModalNotificationCard(notif) {
        const typeIcons = {
            'task_assigned': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>`,
            'task_completed': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
            'task_updated': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
            'task_status_changed': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>`,
            'project_update': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>`,
            'deadline_soon': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
            'comment': `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`
        };

        const typeColors = {
            'task_assigned': 'bg-accent-light/10 border-accent-light/30 text-accent',
            'task_completed': 'bg-green-50 border-green-200 text-green-700',
            'task_updated': 'bg-yellow-50 border-yellow-200 text-yellow-700',
            'task_status_changed': 'bg-orange-50 border-orange-200 text-orange-700',
            'project_update': 'bg-purple-50 border-purple-200 text-purple-700',
            'deadline_soon': 'bg-red-50 border-red-200 text-red-700',
            'comment': 'bg-primary-50 border-primary-200 text-primary-600'
        };

        const icon = typeIcons[notif.type] || `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>`;
        const colorClass = typeColors[notif.type] || 'bg-primary-50 border-primary-200 text-primary-600';
        const unreadStyle = !notif.is_read ? 'border-l-4 border-l-accent-light' : '';

        return `
            <div class="border ${colorClass} ${unreadStyle} rounded-lg hover:shadow-md transition-all cursor-pointer overflow-hidden" 
                 onclick="handleModalNotificationClick(${notif.id})">
                <div class="p-3">
                    <div class="flex items-start gap-3">
                        ${!notif.is_read ? '<div class="w-2 h-2 bg-accent-light rounded-full mt-2 shrink-0"></div>' : '<div class="w-2 shrink-0"></div>'}
                        <div class="shrink-0">${icon}</div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm leading-snug ${!notif.is_read ? 'font-semibold text-primary-700' : 'text-primary-600'}">${notif.message}</p>
                            
                            <div class="mt-2 space-y-1">
                                ${notif.project_title ? `
                                    <div class="flex items-center gap-1 text-xs">
                                        <svg class="w-3 h-3 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
                                        </svg>
                                        <span class="text-primary-600">${notif.project_title}</span>
                                    </div>
                                ` : ''}
                                
                                ${notif.sender_name ? `
                                    <div class="flex items-center gap-1 text-xs text-primary-500">
                                        <span>by ${notif.sender_name}</span>
                                    </div>
                                ` : ''}
                            </div>
                            
                            <div class="flex items-center justify-between mt-2">
                                <span class="text-xs text-primary-500/70">${formatModalDate(notif.created_at)}</span>
                                ${!notif.is_read ? '<span class="px-2 py-0.5 bg-accent-light/20 text-accent text-xs rounded-full font-medium">New</span>' : ''}
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="bg-primary-50/50 px-3 py-2 flex justify-end gap-2 border-t border-neutral-light">
                    ${!notif.is_read ? `
                        <button onclick="markAsReadModal(${notif.id}, event)" 
                                class="px-2 py-1 text-xs text-green-600 hover:bg-green-50 rounded transition flex items-center gap-1"
                                title="Mark as read">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            Read
                        </button>
                    ` : ''}
                    <button onclick="deleteModalNotification(${notif.id}, event)" 
                            class="px-2 py-1 text-xs text-red-600 hover:bg-red-50 rounded transition flex items-center gap-1"
                            title="Delete">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                        Delete
                    </button>
                </div>
            </div>
        `;
    }

    //  ACTIONS 
    window.handleModalNotificationClick = async function(notificationId) {
        const notif = modalNotifications.find(n => n.id === notificationId);
        if (!notif) return;

        console.log(' [MODAL] Clic sur notification:', notificationId);

        // Marquer comme lu si non lu
        if (!notif.is_read) {
            await markAsReadModal(notificationId);
        }

        // Redirection selon le type
        if (notif.project_id) {
            closeNotificationModal();
            window.location.href = `/projects/show/${notif.project_id}`;
        } else if (notif.task_id) {
            try {
                const response = await fetch(`/tasks/${notif.task_id}`, {
                    headers: {
                        'Authorization': `Bearer ${modalUserToken}`,
                        'Content-Type': 'application/json'
                    }
                });
                
                if (response.ok) {
                    const task = await response.json();
                    closeNotificationModal();
                    window.location.href = `/projects/${task.project_id}/tasks`;
                }
            } catch (error) {
                console.error(' [MODAL] Erreur récupération tâche:', error);
            }
        }
    };

    window.markAsReadModal = async function(notificationId, event = null) {
        if (event) event.stopPropagation();

        console.log(' [MODAL] Marquage comme lu:', notificationId);

        try {
            const response = await fetch(`/notifications/mark-read/${notificationId}`, {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${modalUserToken}`,
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) throw new Error('Erreur marquage');

            await loadNotificationsModal();

        } catch (error) {
            console.error(' [MODAL] Erreur marquage:', error);
        }
    };

    window.markAllAsReadModal = async function() {
        const unreadCount = modalNotifications.filter(n => !n.is_read).length;
        
        console.log(' [MODAL] Tentative marquage global:', unreadCount);
        
        if (unreadCount === 0) {
            alert('No unread notifications');
            return;
        }

        if (!confirm(`Mark ${unreadCount} notifications as read?`)) return;

        try {
            const response = await fetch('/notifications/mark-all-read', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${modalUserToken}`,
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) throw new Error('Erreur');

            console.log(' [MODAL] Toutes les notifications marquées');
            await loadNotificationsModal();

        } catch (error) {
            console.error(' [MODAL] Erreur:', error);
        }
    };

    window.deleteModalNotification = async function(notificationId, event = null) {
        if (event) event.stopPropagation();

        console.log('[MODAL] Suppression:', notificationId);

        try {
            const response = await fetch(`/notifications/delete/${notificationId}`, {
                method: 'DELETE',
                headers: {
                    'Authorization': `Bearer ${modalUserToken}`,
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) throw new Error('Erreur de suppression');

            await loadNotificationsModal();

        } catch (error) {
            console.error(' [MODAL] Erreur suppression:', error);
        }
    };

    window.deleteAllNotificationsModal = async function() {
        console.log(' [MODAL] Tentative suppression globale:', modalNotifications.length);
        
        if (modalNotifications.length === 0) {
            alert('No notifications to delete');
            return;
        }

        if (!confirm(`Delete all ${modalNotifications.length} notifications?`)) return;

        try {
            const response = await fetch('/notifications/delete-all', {
                method: 'DELETE',
                headers: {
                    'Authorization': `Bearer ${modalUserToken}`,
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) throw new Error('Erreur');

            console.log(' [MODAL] Toutes les notifications supprimées');
            await loadNotificationsModal();

        } catch (error) {
            console.error(' [MODAL] Erreur:', error);
        }
    };

    window.refreshNotificationsModal = function() {
        console.log(' [MODAL] Rafraîchissement manuel');
        loadNotificationsModal();
    };

    //  MISE À JOUR DES BADGES 
    function updateModalBadges() {
        const unreadCount = modalNotifications.filter(n => !n.is_read).length;
        
        console.log(' [MODAL] Mise à jour des badges:', unreadCount);
        
        // Utiliser le système centralisé si disponible
        if (window.NotificationSync) {
            window.NotificationSync.setCount(unreadCount, 'modal');
            console.log(' [MODAL] Badges mis à jour via NotificationSync');
        } else {
            
            console.warn(' [MODAL] NotificationSync non disponible - Fallback');
            window.dispatchEvent(new CustomEvent('notificationsUpdated', { 
                detail: { 
                    unreadCount: unreadCount,
                    source: 'modal'
                } 
            }));
        }
    }
// FORMATAGE DE DATE 
function formatModalDate(dateString) {
    if (!dateString) {
        console.warn(' [MODAL] No date provided');
        return 'Just now';
    }
    
    console.log(' [MODAL] Formatage de:', dateString);
    
    try {
        let date;
        
        // Format ISO avec T 
        if (dateString.includes('T')) {
            date = new Date(dateString);
            console.log(' [MODAL] Format ISO détecté');
        }
        // Format SQL 
        else if (dateString.includes(' ')) {
            // Remplacer l'espace par un T pour parsing ISO
            const isoFormat = dateString.replace(' ', 'T');
            date = new Date(isoFormat);
            console.log(' [MODAL] Format SQL converti');
        }
        // Autres formats
        else {
            date = new Date(dateString);
            console.log(' [MODAL] Format générique');
        }
        
        // Vérifier validité
        if (isNaN(date.getTime())) {
            console.error(' [MODAL] Date invalide:', dateString);
            return 'Invalid date';
        }
        
        const now = new Date();
        const diffInSeconds = Math.floor((now - date) / 1000);
        
        console.log(' [MODAL] Différence:', diffInSeconds, 'secondes');
        
        // Si date future (tolérance 120s)
        if (diffInSeconds < -120) {
            console.warn(' [MODAL] Date future:', dateString);
            return 'Just now';
        }
        
        // Moins de 1 minute
        if (diffInSeconds >= -120 && diffInSeconds < 60) {
            console.log(' [MODAL] → Just now');
            return 'Just now';
        }
        
        // Moins d'une heure : minutes
        if (diffInSeconds < 3600) {
            const minutes = Math.floor(diffInSeconds / 60);
            console.log(' [MODAL] →', minutes, 'min ago');
            return `${minutes}min ago`;
        }
        
        // Moins de 24 heures : heures
        if (diffInSeconds < 86400) {
            const hours = Math.floor(diffInSeconds / 3600);
            console.log(' [MODAL] →', hours, 'h ago');
            return `${hours}h ago`;
        }
        
        // Plus de 24 heures : date complète
        const options = {
            month: 'short',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
            hour12: false
        };
        
        const formatted = date.toLocaleDateString('en-US', options);
        
        // Ajouter l'année si différente
        if (date.getFullYear() !== now.getFullYear()) {
            console.log(' [MODAL] →', formatted + ', ' + date.getFullYear());
            return `${formatted}, ${date.getFullYear()}`;
        }
        
        console.log('[MODAL] →', formatted);
        return formatted;
        
    } catch (e) {
        console.error(' [MODAL] Erreur formatage:', e);
        console.error(' [MODAL] Input:', dateString);
        return 'Invalid date';
    }
}

    // DÉMARRAGE
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initNotificationModal);
    } else {
        initNotificationModal();
    }

    // NETTOYAGE À LA FERMETURE
    window.addEventListener('beforeunload', () => {
        if (modalUpdateInterval) {
            clearInterval(modalUpdateInterval);
            console.log(' [MODAL] Intervalle nettoyé');
        }
    });

    // FERMER AVEC LA TOUCHE ÉCHAP 
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            const modal = document.getElementById('notificationModal');
            if (modal && modal.classList.contains('show')) {
                closeNotificationModal();
            }
        }
    });
    
    console.log('[MODAL] Script modal notifications chargé et prêt');
})();
</script>

